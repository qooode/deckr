# ============================================
# 🃏 DECKR — Discord Card Bot
# ============================================
# Copy this file to .env and fill in the values
# ============================================

# Required: Your Discord bot token
# Get it from: https://discord.com/developers/applications → Bot → Token
DISCORD_TOKEN=

# Required: Your bot's application/client ID
# Get it from: https://discord.com/developers/applications → General → Application ID
DISCORD_CLIENT_ID=

# Required: Your Discord server (guild) ID
# Enable Developer Mode in Discord → Right-click server → Copy Server ID
DISCORD_GUILD_ID=

# Required: Comma-separated list of admin Discord user IDs
# Right-click yourself in Discord → Copy User ID
DISCORD_ADMIN_IDS=

# Optional: Claim cooldown in minutes (default: 1440 = 24 hours)
CLAIM_COOLDOWN_MINUTES=1440
