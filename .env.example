# ============================================
# 🃏 DECKR — Discord Card Bot
# ============================================
# Copy this file to .env and fill in the values
# ============================================

# Required: Your Discord bot token
# Get it from: https://discord.com/developers/applications → Bot → Token
DISCORD_TOKEN=

# Optional: Override the bot's application/client ID (auto-extracted from token)
# Only needed if auto-detection doesn't work
DISCORD_CLIENT_ID=

# Optional: Your Discord server (guild) ID
# If set, commands register instantly to that server only
# If omitted, commands register globally (takes up to 1h to appear)
DISCORD_GUILD_ID=

# Required: Comma-separated list of admin Discord user IDs
# Right-click yourself in Discord → Copy User ID
DISCORD_ADMIN_IDS=

# Optional: Claim cooldown in minutes (default: 1440 = 24 hours)
CLAIM_COOLDOWN_MINUTES=1440

# Optional: Image URL shown on the face-down claim embed
# Host any card-back image and paste the direct URL here
CLAIM_IMAGE_URL=
